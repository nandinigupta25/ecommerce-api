{
  "info": {
    "name": "E-Commerce API",
    "description": "Complete Postman collection for the E-Commerce Spring Boot REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8080/api" },
    { "key": "adminToken",    "value": "" },
    { "key": "customerToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"username\": \"janesmith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password@1\",\n  \"phoneNumber\": \"9876543211\",\n  \"address\": \"789 Test Street\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.data && json.data.token) {",
                "  pm.collectionVariables.set('adminToken', json.data.token);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@1234\"\n}"
            }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.data && json.data.token) {",
                "  pm.collectionVariables.set('customerToken', json.data.token);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"Customer@1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Updated\",\n  \"phoneNumber\": \"9999988888\",\n  \"address\": \"New Address, Mumbai\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/me/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Customer@1234\",\n  \"newPassword\": \"NewPass@1234\",\n  \"confirmPassword\": \"NewPass@1234\"\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Admin - Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        },
        {
          "name": "Get Category by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories/1" }
        },
        {
          "name": "Admin - Create Category",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toys\",\n  \"description\": \"Kids toys and games\"\n}"
            }
          }
        },
        {
          "name": "Admin - Update Category",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/categories/6",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toys & Games\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Admin - Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/categories/6",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=0&size=10&sortBy=createdAt&sortDir=desc",
              "query": [
                { "key": "page",    "value": "0" },
                { "key": "size",    "value": "10" },
                { "key": "sortBy",  "value": "createdAt" },
                { "key": "sortDir", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/1" }
        },
        {
          "name": "Get Products by Category",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/category/1" }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/search?keyword=iphone&page=0&size=5",
              "query": [
                { "key": "keyword", "value": "iphone" },
                { "key": "page",    "value": "0" },
                { "key": "size",    "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Admin - Create Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MacBook Pro M3\",\n  \"description\": \"Apple MacBook Pro 14-inch M3 chip, 16GB RAM\",\n  \"price\": 199999.00,\n  \"stockQuantity\": 30,\n  \"imageUrl\": \"https://example.com/macbook.jpg\",\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "Admin - Update Product",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/products/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15 Pro Max\",\n  \"description\": \"Updated description\",\n  \"price\": 149999.00,\n  \"stockQuantity\": 40,\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "Admin - Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "View Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/items",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 2,\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/cart/items/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart/items/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"123 Main Street, Apartment 4B, Mumbai, Maharashtra 400001\",\n  \"paymentMethod\": \"CASH_ON_DELIVERY\",\n  \"notes\": \"Please call before delivery\"\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/orders/1/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Admin - Get All Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/orders?page=0&size=10",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Admin - Update Order Status",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/admin/orders/1/status?status=CONFIRMED",
              "query": [{ "key": "status", "value": "CONFIRMED" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    }
  ]
}
